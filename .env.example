# ── Required (3 things to set) ────────────────────────────────────────────────

# 1. Anthropic Claude API — get at console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# 2. Your login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# 3. Database — use Vercel Storage (Postgres) inside the Vercel dashboard
#    It sets DATABASE_URL automatically. No separate signup needed.
DATABASE_URL=

# ── Auto-handled ──────────────────────────────────────────────────────────────
# NEXTAUTH_SECRET — derived from ADMIN_PASSWORD automatically, not required
# NEXTAUTH_URL    — Vercel sets this to your deployment URL automatically
NEXTAUTH_URL=http://localhost:3000

# ── Optional ──────────────────────────────────────────────────────────────────
# Tavily — free 1000 web searches/month at app.tavily.com
# Enables live internet search in chat (e.g. "latest RNOR rules 2025")
TAVILY_API_KEY=
